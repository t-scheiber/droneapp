# Copy this file to .env.local and set your secure passphrase
# This file is safe to commit to GitHub as it contains no secrets

# Application Passphrase - CHANGE THIS TO YOUR SECURE PASSPHRASE
# This will be used for authentication in the drone document viewer
NEXT_PUBLIC_DRONE_PASSPHRASE=your-secure-passphrase-here

# Example: NEXT_PUBLIC_DRONE_PASSPHRASE=drone2024
# Example: NEXT_PUBLIC_DRONE_PASSPHRASE=my-secret-drone-key
